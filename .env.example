# ReviewIQ environment — ALL OPTIONAL. The app runs with zero config.
# Copy to .env.local and uncomment what you need.

# --- Hosting tier (open-core) ------------------------------------------------
# Leave UNSET for self-host (single-tenant, bring-your-own-key, no billing).
# The maintainer's managed/hosted deploy sets HOSTED=true, which switches AI
# provider resolution to require a server API key (below) and disables the
# self-host `claude -p` fallback. Self-hosters should not set this.
# HOSTED=true

# --- Secrets at rest ---------------------------------------------------------
# Encrypts BYOK API keys before they're written to SQLite.
# If unset, a random secret is generated once and stored at DATA_DIR/.app_secret
# (fine for single-box self-host). SET THIS EXPLICITLY on hosted / multi-instance
# deploys so the secret survives volume resets and every instance can decrypt.
#   generate one with:  openssl rand -hex 32
# APP_SECRET=

# --- Storage -----------------------------------------------------------------
# Where SQLite (app.db) and the .app_secret file live.
# Defaults to ./data locally; set to a mounted volume (e.g. /data) in production.
# DATA_DIR=./data

# --- AI provider (optional server-wide default) ------------------------------
# These are only used when the in-app Settings provider is empty.
# Resolution order: Settings (UI)  ->  these env keys  ->  local `claude -p`.

# Anthropic (Claude API)
# ANTHROPIC_API_KEY=sk-ant-...

# Any OpenAI-compatible provider (OpenAI, Fireworks, Groq, OpenRouter, Ollama, ...)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Model id for the env-key default (provider default if unset)
# LLM_MODEL=

# --- Server ------------------------------------------------------------------
# PORT=3000
